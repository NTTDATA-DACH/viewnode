const kubeConfigFixture = `apiVersion: v1
kind: Config
preferences: {}
users:
- name: user-a
  user:
    token: abc
clusters:
- name: cluster-a
  cluster:
    insecure-skip-tls-verify: true
    server: https://127.0.0.1:8080
contexts:
- name: dev-cluster
  context:
    cluster: cluster-a
